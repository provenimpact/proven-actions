{
  "name": "skill-stats",
  "version": "1.0.0",
  "description": "GitHub Action that analyzes Agent Skills and reports token cost statistics",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "npx rimraf dist && rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "all": "npm run lint && npm run test && npm run build",
    "analyze": "tsx scripts/generate-badges.ts"
  },
  "keywords": [
    "github-actions",
    "agent-skills",
    "token-counting",
    "tiktoken"
  ],
  "author": "ProvenImpact",
  "license": "Apache-2.0",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/glob": "^0.6.1",
    "gray-matter": "^4.0.3",
    "tiktoken": "^1.0.22",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@cucumber/gherkin": "^39.0.0",
    "@cucumber/messages": "^32.2.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.4.0",
    "rimraf": "^6.1.3",
    "rollup": "^4.59.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
